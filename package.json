{
  "name": "salesforce-api-playground",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "24.x",
    "npm": ">=10"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start -p ${PORT:-3000}",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "slds:lint": "slds-linter lint . --config-eslint slds-linter.eslint.config.mjs",
    "slds:lint:fix": "slds-linter lint . --fix --config-eslint slds-linter.eslint.config.mjs",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@salesforce-ux/design-system": "^2.30.4",
    "jsforce": "^3.10.15",
    "next": "^15.5.18",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "overrides": {
    "postcss": "8.5.10"
  },
  "devDependencies": {
    "@salesforce-ux/eslint-plugin-slds": "^1.2.1",
    "@salesforce-ux/slds-linter": "^1.2.1",
    "@types/node": "^24.0.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.5.18",
    "typescript": "^5.7.3",
    "vitest": "^4.1.5"
  }
}
